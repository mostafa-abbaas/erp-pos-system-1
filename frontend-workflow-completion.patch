+    setLoading(true); setError('');
+    try {
+      await inventoryApi.count({ branchId, items: countedItems });
+      onSuccess();
+    } catch (e: any) {
+      setError(e.message || 'فشل تنفيذ الجرد');
+    } finally {
+      setLoading(false);
+    }
