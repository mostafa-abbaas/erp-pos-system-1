# ── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql://erp_user:YOUR_DB_PASSWORD@127.0.0.1:5432/erp_pos

# ── JWT (use long random strings in production) ──────────
JWT_SECRET=replace_with_64_char_random_string_in_production
JWT_REFRESH_SECRET=replace_with_different_64_char_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Uploads ──────────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
